direction: right

title: 9 Security Question Categories {
  shape: text
  style.font-size: 20
}

categories: {
  grid-columns: 3

  c1: "1. Policy & People" {
    style.fill: "#e3f2fd"
    topics: |md
      - Training
      - NDAs
      - Background checks
      - Acceptable Use Policy
    |
  }

  c2: "2. Risk Management" {
    style.fill: "#e8f5e9"
    topics: |md
      - Assessments
      - SOC reports
      - Certifications
      - Audits
    |
  }

  c3: "3. Incident Management" {
    style.fill: "#fff3e0"
    topics: |md
      - SIRT
      - Breach notification
      - Forensics
      - Response procedures
    |
  }

  c4: "4. Physical Security" {
    style.fill: "#fce4ec"
    topics: |md
      - CSP-inherited
      - Visitor management
      - Media destruction
      - Data centers
    |
  }

  c5: "5. Infrastructure" {
    style.fill: "#f3e5f5"
    topics: |md
      - Encryption
      - MFA
      - Patching
      - Network security
    |
  }

  c6: "6. Application Security" {
    style.fill: "#e1f5fe"
    topics: |md
      - SDLC
      - Environment segregation
      - Code review
      - Vulnerability scanning
    |
  }

  c7: "7. Access Control" {
    style.fill: "#e0f2f1"
    topics: |md
      - SCIM
      - Password policies
      - Least privilege
      - Access reviews
    |
  }

  c8: "8. Business Continuity" {
    style.fill: "#fff8e1"
    topics: |md
      - Disaster recovery
      - RTO/RPO
      - Backups
      - Geographic redundancy
    |
  }

  c9: "9. Data Security" {
    style.fill: "#efebe9"
    topics: |md
      - PCI
      - PII handling
      - Subprocessors
      - Data classification
    |
  }
}
