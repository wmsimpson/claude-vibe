  shape: diamond
  style.fill: "#e1bee7"
}

ready: "READY TO SHARE" {
  shape: hexagon
  style.fill: "#4caf50"
  style.font-color: white
}

needs_review: "NEEDS REVIEW" {
  shape: hexagon
  style.fill: "#ff9800"
  style.font-color: white
}

escalate: "ESCALATE" {
  shape: hexagon
  style.fill: "#f44336"
  style.font-color: white
}

# Flow
start -> check1
check1 -> check1_result
check1 -> check2

check2 -> check2_result
check2 -> check3

check3 -> check3_result
check3 -> check4

check4 -> check4_result
check4 -> check5

check5 -> check5_result
check5 -> check6

check6 -> check6_result
check6 -> check7

check7 -> check7_result
