# ~/.vibe/env — sourced automatically by ~/.zprofile
# Copy this file to ~/.vibe/env and fill in your values
#
# This file holds tokens and secrets. NEVER commit it to git.

# Google Cloud project ID (required for Sheets, Slides, Forms APIs)
export GCP_QUOTA_PROJECT=your-gcp-project-id

# GitHub Personal Access Token (optional — enables GitHub MCP)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org, gist
# export GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Slack Bot Token (optional — enables Slack MCP)
# Create app at: https://api.slack.com/apps
# Required scopes: channels:history, channels:read, chat:write, users:read
# export SLACK_BOT_TOKEN=xoxb-...
# export SLACK_TEAM_ID=T0XXXXXXXXX

# JIRA API Token (optional — enables JIRA MCP)
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
# export JIRA_URL=https://your-org.atlassian.net
# export JIRA_USERNAME=your-email@example.com
# export JIRA_API_TOKEN=...

# Brave Search API Key (optional — 1000 free queries/month)
# Get at: https://brave.com/search/api/
# export BRAVE_API_KEY=BSA-...

# Notion Integration Token (optional)
# Create at: https://www.notion.so/my-integrations
# export NOTION_API_TOKEN=secret_...

# Anthropic API Key (optional — use API instead of Claude subscription)
# export ANTHROPIC_API_KEY=sk-ant-...
